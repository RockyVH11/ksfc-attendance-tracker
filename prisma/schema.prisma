// KSFC Attendance Tracker — Neon + Vercel (PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  COACH
  PLAYER
}

enum SeasonStatus {
  ACTIVE
  ARCHIVED
}

enum SessionKind {
  PLANNED
  ACTUAL
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  DELETED
}

enum AttendanceStatus {
  YES
  NO
  NOT_COMMUNICATED
}

enum GameStatus {
  SCHEDULED
  COMPLETED
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  name         String
  passwordHash String
  role         UserRole @default(COACH)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  teamAccess UserTeamAccess[]
  player     Player?
}

model UserTeamAccess {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([teamId])
}

model Team {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  players    Player[]
  seasons    Season[]
  sessions   TrainingSession[]
  games      Game[]
  teamAccess UserTeamAccess[]
}

model Season {
  id         String       @id @default(cuid())
  teamId     String
  label      String
  status     SeasonStatus @default(ACTIVE)
  startedAt  DateTime     @default(now())
  archivedAt DateTime?

  team     Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  sessions TrainingSession[]
  games    Game[]

  @@index([teamId, status])
}

model Player {
  id        String   @id @default(cuid())
  teamId    String
  firstName String
  lastName  String
  isActive  Boolean  @default(true)
  userId    String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team        Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user        User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  attendance  AttendanceRecord[]
  gameEntries GameAppearance[]

  @@unique([teamId, firstName, lastName])
  @@index([teamId, isActive])
}

model TrainingSession {
  id               String        @id @default(cuid())
  teamId           String
  seasonId         String
  sessionDate      DateTime      @db.Date
  kind             SessionKind
  status           SessionStatus @default(ACTIVE)
  plannedSessionId String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  team           Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  season         Season             @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  plannedSession TrainingSession?   @relation("PlannedToActual", fields: [plannedSessionId], references: [id], onDelete: SetNull)
  actualSessions TrainingSession[]  @relation("PlannedToActual")
  records        AttendanceRecord[]

  @@index([teamId, seasonId, kind, status])
  @@index([teamId, seasonId, sessionDate])
}

model AttendanceRecord {
  id               String            @id @default(cuid())
  sessionId        String
  playerId         String
  status           AttendanceStatus?
  performanceScore Int?
  notes            String?
  updatedAt        DateTime          @updatedAt

  session TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  player  Player          @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([sessionId, playerId])
}

model Game {
  id             String     @id @default(cuid())
  teamId         String
  seasonId       String
  gameDate       DateTime   @db.Date
  gameTime       String?
  opponent       String
  teamNotes      String?
  opponentNotes  String?
  status         GameStatus @default(SCHEDULED)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  team        Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  season      Season           @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  appearances GameAppearance[]

  @@index([teamId, seasonId, gameDate])
}

model GameAppearance {
  id        String   @id @default(cuid())
  gameId    String
  playerId  String
  isPlaying Boolean  @default(false)
  goals     Int      @default(0)
  assists   Int      @default(0)
  rating    Int?
  notes     String?
  updatedAt DateTime @updatedAt

  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([gameId, playerId])
}
